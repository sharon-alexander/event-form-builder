# Tripleseat public key — from your lead form's API endpoint URL (the value after ?public_key=)
# Settings > Lead Forms > View Setup Codes > API Endpoint
VITE_TRIPLESEAT_PUBLIC_KEY=your_public_key_here

# Lead form to attribute submissions to (numeric ID only, NOT the full URL).
# Find your IDs at: https://api.tripleseat.com/v1/lead_forms.json?public_key=YOUR_KEY
VITE_TRIPLESEAT_LEAD_FORM_ID=

# Location ID for the lead (the location tied to the lead form above).
# It is listed alongside each form in the lead_forms.json response.
VITE_TRIPLESEAT_LOCATION_ID=

# Public site URL (optional). Used for gallery image paths in production builds.
# Defaults to https://event-form-builder.vercel.app when not set.
# VITE_SITE_URL=https://event-form-builder.vercel.app
