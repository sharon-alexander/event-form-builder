# ──────────────────────────────────────────────────────────────────────────────
# Multi-location event form builder — environment variables
#
# Each location has its own Tripleseat credentials. Set the variables for
# whichever locations you're deploying.
# ──────────────────────────────────────────────────────────────────────────────

# ── Pearl Box Townhouse ──────────────────────────────────────────────────────
VITE_PEARL_BOX_TRIPLESEAT_PUBLIC_KEY=
VITE_PEARL_BOX_TRIPLESEAT_LEAD_FORM_ID=
VITE_PEARL_BOX_TRIPLESEAT_LOCATION_ID=

# ── Roscioli ─────────────────────────────────────────────────────────────────
VITE_ROSCIOLI_TRIPLESEAT_PUBLIC_KEY=
VITE_ROSCIOLI_TRIPLESEAT_LEAD_FORM_ID=
VITE_ROSCIOLI_TRIPLESEAT_LOCATION_ID=

# ── Tokyo Record Bar ─────────────────────────────────────────────────────────
VITE_TRB_TRIPLESEAT_PUBLIC_KEY=
VITE_TRB_TRIPLESEAT_LEAD_FORM_ID=
VITE_TRB_TRIPLESEAT_LOCATION_ID=

# ── Shared ───────────────────────────────────────────────────────────────────
# Public site URL (optional). Used for gallery image paths in production builds.
# Defaults to https://event-form-builder.vercel.app when not set.
# VITE_SITE_URL=https://event-form-builder.vercel.app
